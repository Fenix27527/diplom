<Window x:Class="PersonelRecords.Modules.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PersonelRecords.Modules"
        mc:Ignorable="d"
        Title="HistoryWindow" Height="450" Width="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        
        <Image Source="/Resources/bg/bgRegistration.jpg" Grid.ColumnSpan="3" Grid.RowSpan="6" Stretch="UniformToFill"/>
        <ListBox x:Name="ListHistory" Grid.Column="0" Margin="0,0,10,0"
                     SelectionChanged="ListHistory_SelectionChanged"/>


        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="До изменения:" FontWeight="Bold" FontSize="16" Margin="0,15,0,5"/>
            <TextBlock Grid.Row="1" Name="OldValuesTextBlock" Text="(нет данных)" TextWrapping="Wrap" Margin="0,0,0,15" Background="#F0F0F0" Padding="5"/>
            <TextBlock Grid.Row="2" Text="После изменения:" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="3" Name="NewValuesTextBlock" Text="(нет данных)" TextWrapping="Wrap" Margin="0,0,0,15" Background="#F0F0F0" Padding="5"/>
            <StackPanel Grid.Row="4" Orientation="Horizontal">
                <TextBlock Text="Тип операции: " FontWeight="Bold" FontSize="16"/>
                <TextBlock x:Name="TBType" FontWeight="Bold" FontSize="16" Text="—"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
